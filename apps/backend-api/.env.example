# App config
PROJECT_NAME="EcoTrace Carbon Footprint API"
ENVIRONMENT="development"
PORT=8000

# Security configs
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY="replace_me_with_a_secure_random_hex_key"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database configs
# Connect to PostgreSQL: postgresql://user:password@host:port/dbname
DATABASE_URL="sqlite:///./ecotrace.db" # Default fallback for local testing, replace with postgresql:// in production

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
