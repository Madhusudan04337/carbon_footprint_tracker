# =============================================================================
# EcoTrace — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env to source control.
#
# Usage:
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# ── Backend API ───────────────────────────────────────────────────────────────

# Project name shown in FastAPI docs and logs
PROJECT_NAME="EcoTrace Carbon Footprint API"

# Environment: development | production
ENVIRONMENT=production

# Application port (internal container port, not the host-mapped port)
PORT=8000

# Number of gunicorn workers: (2 × CPU cores) + 1 recommended
# Increase to 4 on a 2-core machine, keep at 2 for development
WEB_CONCURRENCY=2

# Log level: debug | info | warning | error | critical
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────────

# JWT secret key — generate with: openssl rand -hex 32
# MUST be changed in production. Rotating this invalidates all active tokens.
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT algorithm — HS256 is standard for symmetric secrets
JWT_ALGORITHM=HS256

# Token expiry in minutes (60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# In docker-compose, HOST = the service name (e.g. "postgres")
DATABASE_URL=postgresql://ecotrace_user:ecotrace_pass@postgres:5432/ecotrace_db

# ── PostgreSQL service credentials (used by the postgres container) ───────────
POSTGRES_USER=ecotrace_user
POSTGRES_PASSWORD=ecotrace_pass
POSTGRES_DB=ecotrace_db

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# Development: http://localhost:5173,http://localhost:8080
# Production:  https://ecotrace.yourdomain.com
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# ── Frontend ──────────────────────────────────────────────────────────────────

# API base URL baked into the frontend bundle at build time (Vite build arg)
# Development: http://localhost:8000/api
# Production:  https://api.ecotrace.yourdomain.com/api
VITE_API_BASE_URL=http://localhost:8000/api
